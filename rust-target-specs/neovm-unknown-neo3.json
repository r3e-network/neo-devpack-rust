{
  "arch": "neovm",
  "data-layout": "e-m:e-p:32:32-i1:8-i8:8-i16:16-i32:32-i64:64-f32:32-f64:64-v16:16-v24:32-v32:32-v48:64-v96:128-v128:128-v256:256-v512:512-v1024:1024",
  "llvm-target": "neovm-unknown-neo3",
  "target-endian": "little",
  "target-pointer-width": "32",
  "target-c-int-width": "32",
  "target-arch": "neovm",
  "target-os": "neo3",
  "target-env": "",
  "target-vendor": "neo",
  "target-family": "unix",
  "features": "+neovm,+i32,+i64,+i1,+i8",
  "linker": "neo-llvm-linker",
  "linker-flavor": "neo-llvm",
  "pre-link-args": {
    "neo-llvm": ["--target=neovm", "--output-format=nef"]
  },
  "post-link-args": {
    "neo-llvm": ["--emit-nef", "--emit-manifest"]
  },
  "panic-strategy": "abort",
  "relocation-model": "static",
  "code-model": "small",
  "tls-model": "local-exec",
  "disable-redzone": true,
  "eliminate-frame-pointer": true,
  "stack-protector": "none",
  "target-features": "+neovm",
  "function-sections": true,
  "data-sections": true,
  "emit-debug-gdb-scripts": false,
  "debugger-tuning": "gdb",
  "needs-plt": false,
  "has-rpath": false,
  "has-tls": false,
  "has-elf-tls": false,
  "has-thread-local": false,
  "is-builtin": false,
  "default-hidden-visibility": true,
  "supports-fx-inline-asm": false,
  "supports-unaligned-loads": true,
  "supports-unaligned-stores": true,
  "min-global-align": "1",
  "max-atomic-width": "32",
  "atomic-cas": false,
  "panic-unwind": false,
  "panic-runtime": false,
  "crt-static": true,
  "crt-static-respected": true,
  "stack-probes": "none",
  "min-llvm-version": "18.0",
  "llvm-abiname": "neovm",
  "llvm-args": ["-target-neovm", "-march=neovm"],
  "linker-is-gnu": false,
  "has-elf-tls": false,
  "has-thread-local": false,
  "needs-plt": false,
  "relro-level": "none",
  "codegen-backend": "llvm",
  "codegen-options": {
    "target-cpu": "neovm",
    "target-feature": "+neovm",
    "llvm-args": ["-target-neovm", "-march=neovm"],
    "panic": "abort",
    "lto": "none",
    "opt-level": "z",
    "debug": false,
    "incremental": false,
    "codegen-units": 1,
    "overflow-checks": false,
    "debug-assertions": false,
    "debuginfo": 0,
    "force-frame-pointers": false,
    "force-unwind-tables": false,
    "symbol-mangling-version": "legacy",
    "relocation-model": "static",
    "code-model": "small"
  }
}
